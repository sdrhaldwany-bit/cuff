local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local CuffingOnMousePress = false
local RemoteEvents = {}
local CuffedTargets = {}
local LoopCuffsEnabled = false
local LoopDelay = 0.01
local AntiCuffPersonal = false
local CuffAllEnabled = false

-- تحديث RemoteEvents
local function UpdateRemoteEvents()
    RemoteEvents = {}
    for _, plr in pairs(Players:GetPlayers()) do
        for _, tool in pairs(plr.Backpack:GetChildren()) do
            local re = tool:FindFirstChildWhichIsA("RemoteEvent")
            if re then table.insert(RemoteEvents, re) end
        end
        if plr.Character then
            for _, tool in pairs(plr.Character:GetChildren()) do
                local re = tool:FindFirstChildWhichIsA("RemoteEvent")
                if re then table.insert(RemoteEvents, re) end
            end
        end
    end
end

-- كلبشة لاعب
local function CuffTarget(target)
    if not target or not target.Character then return end
    local hrp = target.Character:FindFirstChild("HumanoidRootPart") or target.Character:FindFirstChild("Torso")
    if not hrp then return end
    UpdateRemoteEvents()
    for _, re in pairs(RemoteEvents) do
        pcall(function()
            re:FireServer("Cuff", hrp)
        end)
    end
    if not table.find(CuffedTargets, target) then
        table.insert(CuffedTargets, target)
    end
end

-- فك لاعب (أنت فقط)
local function UnCuffTarget(target)
    if not target or not target.Character then return end
    UpdateRemoteEvents()
    for _, re in pairs(RemoteEvents) do
        pcall(function()
            re:FireServer("UnCuff")
        end)
    end
    for i, v in pairs(CuffedTargets) do
        if v == target then
            table.remove(CuffedTargets, i)
        end
    end
end

-- تحديث حركة اللاعبين المكلبشين
RunService.Heartbeat:Connect(function()
    local hrp = LocalPlayer.Character and (LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or LocalPlayer.Character:FindFirstChild("Torso"))
    if hrp then
        for _, target in pairs(CuffedTargets) do
            if target and target.Character then
                local targetHRP = target.Character:FindFirstChild("HumanoidRootPart") or target.Character:FindFirstChild("Torso")
                if targetHRP then
                    targetHRP.CFrame = hrp.CFrame * CFrame.new(0,0,-3)
                end
            end
        end
    end
end)

-- حماية المكلبشين (Anti-UnCuff)
RunService.Heartbeat:Connect(function()
    if AntiCuffPersonal then
        UpdateRemoteEvents()
        for _, re in pairs(RemoteEvents) do
            pcall(function()
                re:FireServer("UnCuff")
            end)
        end
    end
end)

-- عداد اللاعبين الذين لديهم أدوات كلبشة
local function CountPlayersWithCuffs()
    return #CuffedTargets
end

-- GUI
local function CreateGUI()
    local gui = Instance.new("ScreenGui", PlayerGui)
    gui.ResetOnSpawn = false

    local MainFrame = Instance.new("Frame", gui)
    MainFrame.Size = UDim2.fromOffset(180, 430)
    MainFrame.Position = UDim2.new(0.5, -90, 0.5, -215)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20,20,20)
    MainFrame.BackgroundTransparency = 0.1
    MainFrame.BorderSizePixel = 0
    local uicorner = Instance.new("UICorner", MainFrame)
    uicorner.CornerRadius = UDim.new(0, 12)

    -- RGB Effect
    RunService.RenderStepped:Connect(function()
        local t = tick()
        MainFrame.BackgroundColor3 = Color3.fromHSV((t%5)/5,0.7,0.25)
    end)

    local function CreateButton(parent, text, offsetY)
        local btn = Instance.new("TextButton", parent)
        btn.Size = UDim2.fromOffset(160, 35)
        btn.Position = UDim2.fromOffset(10, offsetY)
        btn.Text = text
        btn.TextScaled = true
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
        btn.BackgroundTransparency = 0.2
        local corner = Instance.new("UICorner", btn)
        corner.CornerRadius = UDim.new(0,6)
        return btn
    end

    local offsetY = 10
    local EnableCuffBtn = CreateButton(MainFrame, "Cuffing Disabled", offsetY)
    offsetY = offsetY + 45
    local LoopCuffsBtn = CreateButton(MainFrame, "Loop Cuffs Off", offsetY)
    offsetY = offsetY + 45
    local AntiCuffBtn = CreateButton(MainFrame, "Anti-Cuff: OFF", offsetY)
    offsetY = offsetY + 45
    local CuffAllBtn = CreateButton(MainFrame, "Cuff All: OFF", offsetY)
    offsetY = offsetY + 45
    local PlayersListBtn = CreateButton(MainFrame, "Players List", offsetY)
    offsetY = offsetY + 45

    -- عداد اللاعبين الذين لديهم كلبشة
    local CountLabel = Instance.new("TextLabel", MainFrame)
    CountLabel.Size = UDim2.fromOffset(160, 30)
    CountLabel.Position = UDim2.fromOffset(10, offsetY)
    CountLabel.BackgroundTransparency = 0.2
    CountLabel.BackgroundColor3 = Color3.fromRGB(40,40,40)
    CountLabel.TextColor3 = Color3.fromRGB(255,255,255)
    CountLabel.TextScaled = true
    CountLabel.Text = "Players with Cuffs: 0"
    local uicorner2 = Instance.new("UICorner", CountLabel)
    uicorner2.CornerRadius = UDim.new(0,6)

    -- قائمة اللاعبين
    local PlayersList = Instance.new("ScrollingFrame", gui)
    PlayersList.Size = UDim2.fromOffset(180, 280)
    PlayersList.Position = MainFrame.Position + UDim2.fromOffset(MainFrame.Size.X.Offset + 5,0)
    PlayersList.BackgroundColor3 = Color3.fromRGB(25,25,25)
    PlayersList.BorderSizePixel = 0
    PlayersList.Visible = false
    PlayersList.CanvasSize = UDim2.new(0,0,0,0)
    local uiGrid = Instance.new("UIGridLayout", PlayersList)
    uiGrid.CellSize = UDim2.fromOffset(160, 60)
    uiGrid.CellPadding = UDim2.fromOffset(0,5)
    uiGrid:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        PlayersList.CanvasSize = UDim2.new(0,0,0,uiGrid.AbsoluteContentSize.Y)
    end)

    local function RefreshPlayersList()
        for _, child in pairs(PlayersList:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                local frame = Instance.new("Frame", PlayersList)
                frame.Size = UDim2.fromOffset(160,50)
                frame.BackgroundTransparency = 1

                local nameLabel = Instance.new("TextLabel", frame)
                nameLabel.Size = UDim2.fromOffset(80,25)
                nameLabel.Position = UDim2.fromOffset(5,0)
                nameLabel.Text = p.Name
                nameLabel.TextScaled = true
                nameLabel.BackgroundTransparency = 1
                nameLabel.TextColor3 = Color3.fromRGB(255,255,255)

                local cuffBtn = Instance.new("TextButton", frame)
                cuffBtn.Name = "CuffButton"
                cuffBtn.Size = UDim2.fromOffset(60,20)
                cuffBtn.Position = UDim2.fromOffset(5,25)
                cuffBtn.Text = "Cuff"
                cuffBtn.TextScaled = true
                cuffBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)
                cuffBtn.BackgroundTransparency = 0.2
                local corner = Instance.new("UICorner", cuffBtn)
                corner.CornerRadius = UDim.new(0,4)
                cuffBtn.Activated:Connect(function()
                    CuffTarget(p)
                end)

                local uncuffBtn = Instance.new("TextButton", frame)
                uncuffBtn.Name = "UnCuffButton"
                uncuffBtn.Size = UDim2.fromOffset(60,20)
                uncuffBtn.Position = UDim2.fromOffset(75,25)
                uncuffBtn.Text = "UnCuff"
                uncuffBtn.TextScaled = true
                uncuffBtn.BackgroundColor3 = Color3.fromRGB(80,30,30)
                uncuffBtn.BackgroundTransparency = 0.2
                local corner2 = Instance.new("UICorner", uncuffBtn)
                corner2.CornerRadius = UDim.new(0,4)
                uncuffBtn.Activated:Connect(function()
                    UnCuffTarget(p)
                end)
            end
        end
    end

    -- أزرار التحكم
    EnableCuffBtn.MouseButton1Down:Connect(function()
        CuffingOnMousePress = not CuffingOnMousePress
        EnableCuffBtn.Text = CuffingOnMousePress and "Cuffing Enabled" or "Cuffing Disabled"
    end)

    LoopCuffsBtn.MouseButton1Down:Connect(function()
        LoopCuffsEnabled = not LoopCuffsEnabled
        LoopCuffsBtn.Text = LoopCuffsEnabled and "Loop Cuffs On" or "Loop Cuffs Off"

        if LoopCuffsEnabled then
            spawn(function()
                while LoopCuffsEnabled do
                    RefreshPlayersList()
                    for _, p in pairs(Players:GetPlayers()) do
                        if not LoopCuffsEnabled then break end
                        if p ~= LocalPlayer then
                            CuffTarget(p)
                            wait(LoopDelay)
                        end
                    end
                    wait(0.1)
                end
            end)
        end
    end)

    AntiCuffBtn.MouseButton1Down:Connect(function()
        AntiCuffPersonal = not AntiCuffPersonal
        AntiCuffBtn.Text = AntiCuffPersonal and "Anti-Cuff: ON" or "Anti-Cuff: OFF"
    end)

    CuffAllBtn.MouseButton1Down:Connect(function()
        CuffAllEnabled = not CuffAllEnabled
        if CuffAllEnabled then
            CuffAllBtn.Text = "Cuff All: ON"
            spawn(function()
                while CuffAllEnabled do
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= LocalPlayer then
                            CuffTarget(p)
                            wait(LoopDelay)
                        end
                    end
                    wait(0.05)
                end
            end)
        else
            CuffAllBtn.Text = "Cuff All: OFF"
            -- فك كل اللاعبين المكلبشين فعليًا
            for _, p in pairs(CuffedTargets) do
                if p and p.Character then
                    UpdateRemoteEvents()
                    for _, re in pairs(RemoteEvents) do
                        pcall(function()
                            re:FireServer("UnCuff")
                        end)
                    end
                end
            end
            CuffedTargets = {}
        end
    end)

    PlayersListBtn.MouseButton1Down:Connect(function()
        PlayersList.Visible = not PlayersList.Visible
        if PlayersList.Visible then RefreshPlayersList() end
    end)

    -- تحديث العداد باستمرار
    RunService.RenderStepped:Connect(function()
        CountLabel.Text = "Players with Cuffs: "..tostring(#CuffedTargets)
    end)

    -- زر إخفاء/إظهار GUI
    local HideShowBtn = Instance.new("TextButton", gui)
    HideShowBtn.Size = UDim2.fromOffset(40,40)
    HideShowBtn.Position = UDim2.new(0,10,0.8,0)
    HideShowBtn.Text = "GUI"
    HideShowBtn.TextScaled = true
    HideShowBtn.BackgroundColor3 = Color3.fromRGB(30,150,30)
    local corner3 = Instance.new("UICorner", HideShowBtn)
    corner3.CornerRadius = UDim.new(0,8)

    HideShowBtn.MouseButton1Down:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
        PlayersList.Visible = false
    end)

    -- سحب GUI
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        PlayersList.Position = MainFrame.Position + UDim2.fromOffset(MainFrame.Size.X.Offset + 5,0)
    end
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            dragInput = input
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    MainFrame.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

CreateGUI()
